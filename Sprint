-- Services
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

-- Player variables
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

player.CharacterAdded:Connect(function(newCharacter)
	character = newCharacter
	humanoid = newCharacter:WaitForChild("Humanoid")
end)

-- Configuration
local NORMAL_SPEED = 16
local SPRINT_SPEED = 28
local MAX_STAMINA = 100
local currentStamina = MAX_STAMINA

local DRAIN_RATE = 20 -- Stamina lost per second while sprinting
local REGEN_RATE = 15 -- Stamina gained per second while resting

local isSprinting = false

-- Colors matched to the reference image
local LIGHT_ORANGE = Color3.fromRGB(243, 204, 144) -- The pastel cream/orange fill
local BORDER_BROWN = Color3.fromRGB(139, 87, 42)    -- The thick brown outline
local TEXT_DARK = Color3.fromRGB(20, 20, 20)        -- Soft black for the text
local BG_DARK_ORANGE = Color3.fromRGB(186, 126, 68) -- Background fill for empty bar

-- Create UI Elements
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "SprintGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

-- 1. Main Container Frame (Holds everything together at the bottom right)
local container = Instance.new("Frame")
container.Name = "SprintContainer"
container.Size = UDim2.new(0, 260, 0, 70)
container.Position = UDim2.new(0.8, 0, 0.8, 0) -- Adjusted position
container.BackgroundTransparency = 1
container.Parent = screenGui

-- 2. Stamina Bar Background (Long bar on the bottom)
local staminaBg = Instance.new("Frame")
staminaBg.Name = "StaminaBackground"
staminaBg.Size = UDim2.new(0, 240, 0, 22)
staminaBg.Position = UDim2.new(0, 0, 1, -22) -- Snapped to the bottom of the container
staminaBg.BackgroundColor3 = BG_DARK_ORANGE
staminaBg.BorderSizePixel = 0
staminaBg.Parent = container

local staminaBgCorner = Instance.new("UICorner")
staminaBgCorner.CornerRadius = UDim.new(0, 8)
staminaBgCorner.Parent = staminaBg

local staminaBgStroke = Instance.new("UIStroke")
staminaBgStroke.Thickness = 4
staminaBgStroke.Color = BORDER_BROWN
staminaBgStroke.Parent = staminaBg

-- 3. Actual Stamina Fill Bar
local staminaFill = Instance.new("Frame")
staminaFill.Name = "StaminaFill"
staminaFill.Size = UDim2.new(1, 0, 1, 0)
staminaFill.BackgroundColor3 = LIGHT_ORANGE
staminaFill.BorderSizePixel = 0
staminaFill.Parent = staminaBg

local staminaFillCorner = Instance.new("UICorner")
staminaFillCorner.CornerRadius = UDim.new(0, 8)
staminaFillCorner.Parent = staminaFill

-- 4. Sprint Button (Rounded, sitting on top of the bar to the right)
local sprintButton = Instance.new("TextButton")
sprintButton.Name = "SprintButton"
sprintButton.Size = UDim2.new(0, 100, 0, 42)
sprintButton.Position = UDim2.new(1, -110, 0, 0) -- Top right alignment matching the picture
sprintButton.BackgroundColor3 = LIGHT_ORANGE
sprintButton.BorderSizePixel = 0
sprintButton.AutoButtonColor = true
sprintButton.ZIndex = 3 -- Layered safely on top

-- Stylish Rich Text matching the font look
sprintButton.RichText = true
sprintButton.Text = "<font face='FredokaOne' color='#141414' size='22'>Sprint</font>"
sprintButton.Parent = container

local buttonCorner = Instance.new("UICorner")
buttonCorner.CornerRadius = UDim.new(0, 12)
buttonCorner.Parent = sprintButton

local buttonStroke = Instance.new("UIStroke")
buttonStroke.Thickness = 4
buttonStroke.Color = BORDER_BROWN
buttonStroke.Parent = sprintButton

-- Logic Functions
local function setSprinting(sprinting)
	if sprinting and currentStamina > 0 and humanoid.MoveDirection.Magnitude > 0 then
		isSprinting = true
		humanoid.WalkSpeed = SPRINT_SPEED
		sprintButton.BackgroundColor3 = BG_DARK_ORANGE -- Darkens button slightly when active
	else
		isSprinting = false
		humanoid.WalkSpeed = NORMAL_SPEED
		sprintButton.BackgroundColor3 = LIGHT_ORANGE
	end
end

-- Button Inputs
sprintButton.MouseButton1Down:Connect(function()
	setSprinting(true)
end)

sprintButton.MouseButton1Up:Connect(function()
	setSprinting(false)
end)

-- Keybind Backup (Left Shift)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.LeftShift then
		setSprinting(true)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.LeftShift then
		setSprinting(false)
	end
end)

-- Core Loop for draining/generating stamina
RunService.Heartbeat:Connect(function(deltaTime)
	if isSprinting and humanoid.MoveDirection.Magnitude == 0 then
		setSprinting(false)
	end

	if isSprinting then
		currentStamina = math.max(0, currentStamina - (DRAIN_RATE * deltaTime))
		if currentStamina <= 0 then
			setSprinting(false)
		end
	else
		currentStamina = math.min(MAX_STAMINA, currentStamina + (REGEN_RATE * deltaTime))
	end

	-- Smoothly update the stamina bar size width
	local staminaRatio = currentStamina / MAX_STAMINA
	TweenService:Create(staminaFill, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {
		Size = UDim2.new(staminaRatio, 0, 1, 0)
	}):Play()
end)
